# Copy this file to .env.local and fill in real values

# Google Analytics 4 — from analytics.google.com (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# Google Tag Manager — from tagmanager.google.com (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Search Console verification code — from search.google.com/search-console
# Use "HTML tag" method — copy only the content="..." value
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools verification code — from bing.com/webmasters
NEXT_PUBLIC_BING_VERIFICATION=
